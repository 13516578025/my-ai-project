# 忽略所有 .log 日志文件
*.log

# 忽略 node_modules 目录（Node.js依赖）
node_modules/

# 忽略编译输出目录
dist/
build/

# 忽略操作系统生成的文件
.DS_Store          # Mac系统文件
Thumbs.db          # Windows缩略图缓存

# 忽略IDE配置文件
.idea/             # JetBrains IDE
.vscode/           # VS Code（如果你不想共享配置）

# 忽略敏感配置文件
.env               # 环境变量（可能包含密码）
config.local.js    # 本地配置